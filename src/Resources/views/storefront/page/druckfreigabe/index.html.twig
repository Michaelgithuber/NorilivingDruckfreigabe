{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_main %}

<style>
/* ── Layout ─────────────────────────────────────── */
.df-page          { max-width: 1100px; margin: 40px auto; padding: 0 20px 60px; }
.df-title         { text-align: center; font-size: 28px; font-weight: bold; margin-bottom: 24px; }

/* ── Bestellinfo Box ─────────────────────────────── */
.df-order-box     { border: 1px solid #ddd; padding: 16px 20px; margin-bottom: 32px; font-size: 14px; }
.df-order-box table td:first-child { color: #333; padding-right: 24px; white-space: nowrap; }
.df-order-box table td:last-child  { font-weight: 600; }

/* ── Positionen Grid (2 pro Zeile, auto-wrap) ────── */
.df-positions-grid { display: flex; flex-wrap: wrap; gap: 24px 32px; margin-bottom: 32px; }
.df-position      { flex: 0 0 calc(50% - 16px); display: flex; align-items: flex-start; gap: 12px; padding-bottom: 0; }
.df-row-sep       { flex: 0 0 100%; height: 2px; background: #aaa; margin: 8px 0; }
.df-pos-info      { width: 140px; min-width: 140px; font-size: 12px; line-height: 1.6; }
.df-pos-info .lbl { color: #555; }
.df-pos-info .val { font-weight: 600; color: #c0392b; }
.df-pos-info .val-black { font-weight: 600; color: #222; }

/* ── Platten ─────────────────────────────────────── */
.df-plates        { flex: 1; min-width: 0; }
.df-plates-row    { display: flex; align-items: flex-start; gap: 0; }
.df-plate-col     { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; padding-right: 0; }
.df-plate-img-wrap { width: 100%; overflow: hidden; }
.df-plate-img     { width: 100%; height: auto; display: block; }
.df-plate-dim     { font-size: 11px; margin-top: 3px; }
.df-plate-dim .dim-b { color: #333; }
.df-plate-dim .dim-h { color: #333; }

/* ── Vorschau Zusammenfassung ────────────────────── */
.df-vorschau-wrap  { margin-bottom: 24px; }
.df-vorschau-wrap h3 { font-size: 18px; margin-bottom: 8px; }
.df-vorschau-box   {
    border: 1px solid #ccc;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    height: 200px;
    gap: 5px;
}
.df-vorschau-pos   { display: flex; align-items: stretch; flex: 1; min-width: 0; }
.df-vorschau-item  { flex: 1; min-width: 0; overflow: hidden; }
.df-vorschau-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Hinweistext ─────────────────────────────────── */
.df-notice        { font-style: italic; font-size: 13px; color: #333; margin-bottom: 8px; }
.df-howto         { font-size: 13px; color: #333; margin: 16px 0 24px; line-height: 1.8; }
.df-banner        { display: block; max-width: 100%; margin: 16px 0; }

/* ── Formular ────────────────────────────────────── */
.df-form-row      { display: flex; align-items: center; gap: 16px; margin-top: 12px; flex-wrap: wrap; }
.df-select        { font-size: 14px; padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px; }
.df-btn           {
    background: #27ae60; color: #fff; border: none;
    font-size: 14px; font-weight: 700; padding: 8px 24px;
    border-radius: 4px; cursor: pointer; letter-spacing: 0.5px;
}
.df-btn:hover     { background: #219150; }
.df-btn.btn-no    { background: #e74c3c; }
.df-btn.btn-no:hover { background: #c0392b; }
.df-comment       { width: 100%; margin-top: 12px; }

/* ── Footer ──────────────────────────────────────── */
.df-footer        { text-align: center; font-size: 13px; margin-top: 40px; color: #666; }
.df-footer a      { color: #666; text-decoration: none; }
.df-footer a:hover{ text-decoration: underline; }
</style>

<div class="df-page">

    <div class="df-title">Druckfreigabe</div>

    {# Meldungen #}
    {% if success %}
        <div class="alert alert-success mb-4">
            <strong>Vielen Dank!</strong> Ihre Druckfreigabe wurde erfolgreich übermittelt.
            {% if approvalValue == 'erteilt' %}
                Ihr Auftrag geht in die Produktion. Der Versand erfolgt in ca. 1 Woche.
            {% else %}
                Ihr Auftrag geht in die Grafikabteilung. Sie erhalten eine neue Druckvorschau per Mail.
            {% endif %}
        </div>
    {% endif %}

    {% if error %}
        <div class="alert alert-danger mb-4">{{ error }}</div>
    {% endif %}

    {# Bestellinfo #}
    <div class="df-order-box">
        <table>
            <tr><td>Ihre Bestellung:</td><td>{{ orderInfo.number }}</td></tr>
            <tr><td>Auftragsdatum:</td><td>{{ orderInfo.date }}</td></tr>
            <tr><td>Empfänger:</td><td>{{ orderInfo.name }}</td></tr>
            <tr><td>Lieferadresse:</td><td>{{ orderInfo.address }}</td></tr>
        </table>
    </div>

    {# Positionen #}
    <div class="df-positions-grid">
    {% for position in positions %}
    <div class="df-position">

        {# Info links #}
        <div class="df-pos-info">
            <div class="lbl">Ihre Bestellung:</div>
            <div class="val">{{ position.label }}</div>
            <div class="lbl">Gesamtmenge:</div>
            <div class="val-black">{{ position.menge }}</div>
            <div class="lbl">Material:</div>
            <div class="val-black">{{ position.material }}</div>
            <div class="lbl">Farbigkeit:</div>
            <div class="val">{{ position.farbigkeit }}</div>
            <div class="lbl">Schneiden:</div>
            <div class="val">{{ position.schneiden }}</div>
            <div class="lbl">Veredelung:</div>
            <div class="val">{{ position.veredelung }}</div>
        </div>

        {# Platten #}
        <div class="df-plates">

            {# Platte-Buttons + Bilder + Maße #}
            <div class="df-plates-row">
                {% for plate in position.plates %}
                <div class="df-plate-col" style="flex: {{ plate.breite|default('1') }};">
                    <a href="{{ plate.download }}" target="_blank" class="btn btn-sm btn-primary mb-1">
                        Platte {{ plate.number }}
                    </a>
                    <div class="df-plate-img-wrap">
                        <img
                            src="{{ plate.preview }}"
                            class="df-plate-img"
                            alt="Pos. {{ position.number }} Platte {{ plate.number }}"
                        />
                    </div>
                    <div class="df-plate-dim">
                        <div class="dim-b">Breite: {{ plate.breite }}</div>
                        <div class="dim-h">Höhe: {{ plate.hoehe }}</div>
                    </div>
                </div>
                {% endfor %}
            </div>

        </div>
    </div>
    {% if loop.index is even and not loop.last %}
    <div class="df-row-sep"></div>
    {% endif %}
    {% endfor %}
    </div>{# Ende df-positions-grid #}

    {# Vorschau Zusammenfassung #}
    <div class="df-vorschau-wrap">
        <h3>Vorschau Zusammenfassung</h3>
        <div class="df-vorschau-box">
            {% for position in positions %}
            <div class="df-vorschau-pos" style="flex: {{ position.total_breite }};">
                {% for plate in position.plates %}
                <div class="df-vorschau-item" style="flex: {{ plate.breite|default('1') }};">
                    <img src="{{ plate.preview }}" alt="Pos. {{ position.number }} Pl. {{ plate.number }}" />
                </div>
                {% endfor %}
            </div>
            {% endfor %}
        </div>
    </div>

    {# Hinweistexte #}
    <div class="df-notice">
        Bitte die Originaldatei (Link Platte 1 usw.) in 1:1 unbedingt prüfen!
    </div>
    <div class="df-notice">
        WICHTIG: Bei Nachbestellungen / Ergänzungsbestellungen kann es zu Farbabweichungen kommen!<br>
        Informieren Sie uns bitte vor der Druckfreigabe, falls es sich bei diesem Auftrag um eine Nach- bzw. Ergänzungsbestellung handelt.
    </div>

    {# Erklärungsbanner #}
    <img src="/media/norilivingdruckfreigabe/banner-erklaerung.jpg" class="df-banner" alt="Erklärung Druckfreigabe">

    {# Wie geht es weiter #}
    <div class="df-howto">
        Wie geht es nun weiter?<br>
        Sie geben die Druckdatei frei (wählen Sie "Ja" und klicken Sie auf den Button "DRUCKFREIGABE ERTEILEN")<br>
        Ihr Auftrag geht in die Produktion<br>
        Der Versand wird in ca. 1 Woche erfolgen (früherer Versandzeitpunkt bei bestellter Express-Option)
        <br><br>
        oder
        <br><br>
        Sie teilen uns Ihre Änderungswünsche mit (wählen Sie "Nein", notieren Sie Ihre Änderungswünsche und klicken Sie auf den Button "KEINE DRUCKFREIGABE ERTEILEN")<br>
        Ihr Auftrag geht in die Grafikabteilung<br>
        Sie erhalten eine neue Druckvorschau per Mail
    </div>

    {# Formular #}
    {% if not success %}
    <form method="post" action="{{ path('frontend.druckfreigabe.submit', { orderNumber: orderNumber }) }}">

        <textarea
            id="df-comment"
            name="comment"
            class="form-control df-comment"
            rows="4"
            placeholder="Bitte hier Änderungswünsche eintragen"
            style="display:none;"
        ></textarea>

        <div class="df-form-row">
            <select id="df-select" name="approval" class="df-select">
                <option value="">bitte wählen!</option>
                <option value="ja">Ja</option>
                <option value="nein">Nein</option>
            </select>
            <button type="submit" id="df-btn" class="df-btn">KEINE AUSWAHL</button>
        </div>

    </form>
    {% endif %}

</div>

<div class="df-footer">
    <a href="/impressum">Impressum</a>
    &nbsp;&nbsp;|&nbsp;&nbsp;
    <a href="/kontaktformular">Kontakt</a>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    /* ── Formular Logik ── */
    var select  = document.getElementById('df-select');
    var comment = document.getElementById('df-comment');
    var btn     = document.getElementById('df-btn');

    if (select) {
        select.addEventListener('change', function () {
            if (this.value === 'ja') {
                comment.style.display = 'none';
                btn.textContent = 'DRUCKFREIGABE ERTEILEN';
                btn.className   = 'df-btn';
            } else if (this.value === 'nein') {
                comment.style.display = 'block';
                btn.textContent = 'KEINE DRUCKFREIGABE ERTEILEN';
                btn.className   = 'df-btn btn-no';
            } else {
                comment.style.display = 'none';
                btn.textContent = 'KEINE AUSWAHL';
                btn.className   = 'df-btn';
            }
        });
    }

    /* ── Bildhöhen angleichen (wie WordPress) ── */
    var imgs = Array.from(document.querySelectorAll('.df-plate-img'));
    if (!imgs.length) return;

    var loaded = 0;
    function tryEqualize() {
        loaded++;
        if (loaded < imgs.length) return;
        var heights = imgs.map(function(img) { return img.offsetHeight; }).filter(function(h) { return h > 0; });
        if (!heights.length) return;
        var minH = Math.min.apply(null, heights);
        imgs.forEach(function(img) {
            img.parentElement.style.height = minH + 'px';
        });
    }
    imgs.forEach(function(img) {
        if (img.complete && img.naturalHeight) { setTimeout(tryEqualize, 0); }
        else {
            img.addEventListener('load',  tryEqualize);
            img.addEventListener('error', tryEqualize);
        }
    });

});
</script>

{% endblock %}
