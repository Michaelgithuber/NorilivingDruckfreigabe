{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_main %}

{% if showVerifyForm %}
<div class="df-page" style="max-width:480px; margin:60px auto; padding:0 20px;">
    <h1 class="df-title">Druckfreigabe</h1>
    {% if showLanding is defined and showLanding %}
        {# Landing: Bestellnummer + PLZ beide editierbar #}
        <form method="post" action="{{ path('frontend.druckfreigabe.landing') }}">
            {% if verifyError %}
                <div class="alert alert-danger mb-3">{{ verifyError }}</div>
            {% endif %}
            <div class="mb-3">
                <label class="form-label fw-bold">Bestellnummer:</label>
                <input type="text" class="form-control" name="orderNumber" value="{{ orderNumber }}" required autofocus>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Postleitzahl der Lieferanschrift:</label>
                <input type="text" class="form-control" name="plz" required>
            </div>
            <button type="submit" class="btn btn-primary">BILDER ANZEIGEN</button>
        </form>
    {% else %}
        {# Direktlink /druckfreigabe/{orderNumber}: nur PLZ eingeben #}
        <form method="post" action="{{ path('frontend.druckfreigabe.verify', {orderNumber: orderNumber}) }}">
            {% if verifyError %}
                <div class="alert alert-danger mb-3">{{ verifyError }}</div>
            {% endif %}
            <div class="mb-3">
                <label class="form-label fw-bold">Bestellnummer:</label>
                <input type="text" class="form-control" value="{{ orderNumber }}" readonly>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Postleitzahl der Lieferanschrift:</label>
                <input type="text" class="form-control" name="plz" required autofocus>
            </div>
            <button type="submit" class="btn btn-primary">BILDER ANZEIGEN</button>
        </form>
    {% endif %}
</div>
{% else %}

<style>
/* ── Layout ─────────────────────────────────────── */
.df-page          { max-width: 1400px; margin: 40px auto; padding: 0 30px 60px; }
.df-title         { text-align: center; font-size: 28px; font-weight: bold; margin-bottom: 24px; }

/* ── Bestellinfo Box ─────────────────────────────── */
.df-order-box     { background: #f8f9fa; border-left: 4px solid #1a7f8e; border-radius: 4px; padding: 16px 24px; margin-bottom: 32px; display: flex; flex-wrap: wrap; gap: 8px 48px; }
.df-order-box-item .label { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
.df-order-box-item .value { font-weight: 600; color: #1a1a1a; font-size: 14px; }

/* ── Success Box ─────────────────────────────────── */
.df-success-box   { text-align: center; padding: 40px 32px; border-radius: 12px; margin-bottom: 32px; }
.df-success-ja    { background: #f0faf4; border: 2px solid #27ae60; }
.df-success-nein  { background: #fff8f0; border: 2px solid #e67e22; }
.df-success-icon  { font-size: 52px; margin-bottom: 12px; }
.df-success-title { font-size: 26px; font-weight: bold; margin-bottom: 12px; }
.df-success-title.ja   { color: #27ae60; }
.df-success-title.nein { color: #e67e22; }
.df-success-info  { margin-bottom: 16px; color: #444; }
.df-success-list  { list-style: none; padding: 0; margin: 0 0 20px; display: inline-block; text-align: left; }
.df-success-list li { padding: 4px 0; font-size: 15px; }

/* ── Erlebniswelt ────────────────────────────────── */
.df-erlebniswelt  { margin-bottom: 40px; }

/* ── Positionen Grid (proportionale Breite je Position) ────── */
.df-positions-grid { display: flex; flex-wrap: wrap; gap: 32px 64px; margin-bottom: 32px; }
.df-position      { max-width: 100%; display: flex; align-items: flex-start; gap: 3px; padding-bottom: 0; }
.df-row-sep       { flex: 0 0 100%; height: 2px; background: #aaa; margin: 8px 0; }
.df-pos-info      { width: 140px; min-width: 140px; font-size: 12px; line-height: 1.1; }
.df-pos-info .lbl { color: #555; }
.df-pos-info .val { font-weight: 600; color: #c0392b; }
.df-pos-info .val-black { font-weight: 600; color: #222; }

/* ── Platten ─────────────────────────────────────── */
.df-plates        { flex: 1; min-width: 0; }
.df-plates-row    { display: flex; align-items: stretch; gap: 2px; background: #e0e0e0; }
.df-plate-col     { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; background: #fff; }
.df-plate-img-wrap { width: 100%; }
.df-plate-img     { width: 100%; height: auto; display: block; }
.df-plate-dim     { font-size: 11px; margin-top: 3px; }
.df-plate-dim .dim-b { color: #333; }
.df-plate-dim .dim-h { color: #333; }

/* ── Vorschau Zusammenfassung ────────────────────── */
.df-vorschau-wrap  { margin-bottom: 24px; }
.df-vorschau-wrap h3 { font-size: 18px; margin-bottom: 8px; }
.df-vorschau-box   {
    border: 1px solid #ccc;
    overflow-x: auto;
    overflow-y: hidden;
    display: flex;
    align-items: stretch;
    height: 200px;
    gap: 5px;
}
.df-vorschau-pos   { display: flex; align-items: stretch; flex: 0 0 auto; gap: 0; }
.df-vorschau-item  { flex: 0 0 auto; overflow: hidden; }
.df-vorschau-item img { height: 100%; width: auto; display: block; object-fit: contain; }

/* ── Hinweistext ─────────────────────────────────── */
.df-notice        { font-style: italic; font-size: 13px; color: #333; margin-bottom: 8px; }
.df-howto         { font-size: 13px; color: #333; margin: 16px 0 24px; line-height: 1.8; }
.df-banner        { display: block; max-width: 100%; margin: 16px 0; }

/* ── Formular ────────────────────────────────────── */
.df-form-row      { display: flex; align-items: center; gap: 16px; margin-top: 12px; flex-wrap: wrap; }
.df-select        { font-size: 14px; padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px; }
.df-btn           {
    background: #27ae60; color: #fff; border: none;
    font-size: 14px; font-weight: 700; padding: 8px 24px;
    border-radius: 4px; cursor: pointer; letter-spacing: 0.5px;
}
.df-btn:hover     { background: #219150; }
.df-btn.btn-no    { background: #e74c3c; }
.df-btn.btn-no:hover { background: #c0392b; }
.df-comment       { width: 100%; margin-top: 12px; }

/* ── Footer ──────────────────────────────────────── */
.df-footer        { text-align: center; font-size: 13px; margin-top: 40px; color: #666; }
.df-footer a      { color: #666; text-decoration: none; }
.df-footer a:hover{ text-decoration: underline; }
</style>

<div class="df-page">

    <div class="df-title">Druckfreigabe</div>

    {# ── Bestätigungs-Box nach Absenden ── #}
    {% if success %}
        <div class="df-success-box {{ approvalValue == 'erteilt' ? 'df-success-ja' : 'df-success-nein' }}">
            <div class="df-success-icon">{{ approvalValue == 'erteilt' ? '✅' : '❌' }}</div>
            <div class="df-success-title {{ approvalValue == 'erteilt' ? 'ja' : 'nein' }}">
                Druckfreigabe {{ approvalValue == 'erteilt' ? 'erteilt' : 'abgelehnt' }}!
            </div>
            <p class="df-success-info">Bestellung: <strong>{{ orderInfo.number }}</strong> &nbsp;|&nbsp; {{ orderInfo.name }}</p>
            {% if approvalValue == 'erteilt' %}
                <ul class="df-success-list">
                    <li>🖨 Ihr Auftrag geht jetzt in die <strong>Produktion</strong></li>
                    <li>🚚 Der Versand erfolgt in ca. <strong>1 Woche</strong></li>
                    <li>📧 Sie erhalten eine <strong>Versandbestätigung per Mail</strong></li>
                </ul>
            {% else %}
                <ul class="df-success-list">
                    <li>🎨 Ihr Auftrag geht in die <strong>Grafikabteilung</strong></li>
                    <li>📧 Sie erhalten eine <strong>neue Druckvorschau per Mail</strong></li>
                </ul>
            {% endif %}
            <a href="{{ path('frontend.account.order.page') }}" class="btn btn-outline-secondary btn-sm">← Zurück zu meinen Bestellungen</a>
        </div>

        {# ── Erlebniswelt (CMS-Seite df-erlebniswelt) ── #}
        {% if cmsPage is defined and cmsPage %}
            <div class="df-erlebniswelt">
                {% sw_include '@Storefront/storefront/page/content/detail.html.twig' with { 'cmsPage': cmsPage } %}
            </div>
        {% endif %}
    {% endif %}

    {% if error %}
        <div class="alert alert-danger mb-4">{{ error }}</div>
    {% endif %}

    {# Bestellinfo #}
    <div class="df-order-box">
        <div class="df-order-box-item"><span class="label">Ihre Bestellung</span><span class="value">{{ orderInfo.number }}</span></div>
        <div class="df-order-box-item"><span class="label">Auftragsdatum</span><span class="value">{{ orderInfo.date }}</span></div>
        <div class="df-order-box-item"><span class="label">Empfänger</span><span class="value">{{ orderInfo.name }}</span></div>
        <div class="df-order-box-item"><span class="label">Lieferadresse</span><span class="value">{{ orderInfo.address }}</span></div>
    </div>

    {# Positionen #}
    <div class="df-positions-grid">
    {% for position in positions %}
    <div class="df-position" style="flex: {{ position.total_breite }} 1 {{ (position.total_breite * 0.17 + 152)|round }}px;">

        {# Info links #}
        <div class="df-pos-info">
            <div class="lbl">Ihre Bestellung:</div>
            <div class="val">{{ position.label }}</div>
            <div class="lbl">Gesamtmenge:</div>
            <div class="val-black">{{ position.menge }}</div>
            <div class="lbl">Material:</div>
            <div class="val-black">{{ position.material }}</div>
            <div class="lbl">Farbigkeit:</div>
            <div class="val">{{ position.farbigkeit }}</div>
            <div class="lbl">Schneiden:</div>
            <div class="val">{{ position.schneiden }}</div>
            <div class="lbl">Veredelung:</div>
            <div class="val">{{ position.veredelung }}</div>
        </div>

        {# Platten #}
        <div class="df-plates">

            {# Platte-Buttons + Bilder + Maße #}
            <div class="df-plates-row">
                {% for plate in position.plates %}
                <div class="df-plate-col" style="flex: {{ plate.breite|default('1') }};">
                    <a href="{{ plate.download }}" target="_blank" class="btn btn-sm btn-primary mb-1">
                        Platte {{ plate.number }}
                    </a>
                    <div class="df-plate-img-wrap">
                        <img
                            src="{{ plate.preview }}"
                            class="df-plate-img"
                            alt="Pos. {{ position.number }} Platte {{ plate.number }}"
                        />
                    </div>
                    <div class="df-plate-dim">
                        <div class="dim-b">Breite: {{ plate.breite }}</div>
                        <div class="dim-h">Höhe: {{ plate.hoehe }}</div>
                    </div>
                </div>
                {% endfor %}
            </div>

        </div>
    </div>
    {% if loop.index is even and not loop.last %}
    <div class="df-row-sep"></div>
    {% endif %}
    {% endfor %}
    </div>{# Ende df-positions-grid #}

    {# Vorschau Zusammenfassung #}
    <div class="df-vorschau-wrap">
        <h3>Vorschau Zusammenfassung</h3>
        <div class="df-vorschau-box">
            {% for position in positions %}
            <div class="df-vorschau-pos">
                {% for plate in position.plates %}
                <div class="df-vorschau-item">
                    <img src="{{ plate.preview }}" alt="Pos. {{ position.number }} Pl. {{ plate.number }}" />
                </div>
                {% endfor %}
            </div>
            {% endfor %}
        </div>
    </div>

    {# Hinweistexte #}
    <div class="df-notice">
        <strong>Bitte die Originaldatei (Link Platte 1 usw.) in 1:1 unbedingt prüfen!</strong>
    </div>
    <div class="df-notice">
        <strong>WICHTIG:</strong> Bei Nachbestellungen / Ergänzungsbestellungen kann es zu Farbabweichungen kommen!<br>
        Informieren Sie uns bitte <strong>vor der Druckfreigabe</strong>, falls es sich bei diesem Auftrag um eine Nach- bzw. Ergänzungsbestellung handelt.
    </div>

    {# Erklärungsbanner #}
    <img src="/media/norilivingdruckfreigabe/banner-erklaerung.jpg" class="df-banner" alt="Erklärung Druckfreigabe">

    {# Wie geht es weiter #}
    <div class="df-howto">
        <strong>Wie geht es nun weiter?</strong><br>
        ✅ Wählen Sie <strong>"Ja"</strong> und klicken Sie auf <strong>"DRUCKFREIGABE ERTEILEN"</strong><br>
        → Ihr Auftrag geht in die Produktion<br>
        → Der Versand erfolgt in ca. <strong>1 Woche</strong> (früher bei bestellter Express-Option)
        <br><br>
        ❌ Wählen Sie <strong>"Nein"</strong>, notieren Sie Ihre Änderungswünsche und klicken Sie auf <strong>"KEINE DRUCKFREIGABE ERTEILEN"</strong><br>
        → Ihr Auftrag geht in die Grafikabteilung<br>
        → Sie erhalten eine neue Druckvorschau per Mail
    </div>

    {# Formular #}
    {% if not success %}
    <form method="post" action="{{ path('frontend.druckfreigabe.submit', { orderNumber: orderNumber }) }}">

        <textarea
            id="df-comment"
            name="comment"
            class="form-control df-comment"
            rows="4"
            placeholder="Bitte hier Änderungswünsche eintragen"
            style="display:none;"
        ></textarea>

        <div class="df-form-row">
            <select id="df-select" name="approval" class="df-select">
                <option value="">bitte wählen!</option>
                <option value="ja">Ja</option>
                <option value="nein">Nein</option>
            </select>
            <button type="submit" id="df-btn" class="df-btn">KEINE AUSWAHL</button>
        </div>

    </form>
    {% endif %}

</div>

<div class="df-footer">
    <a href="/impressum">Impressum</a>
    &nbsp;&nbsp;|&nbsp;&nbsp;
    <a href="/kontaktformular">Kontakt</a>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    /* ── Formular Logik ── */
    var select  = document.getElementById('df-select');
    var comment = document.getElementById('df-comment');
    var btn     = document.getElementById('df-btn');

    if (select) {
        select.addEventListener('change', function () {
            if (this.value === 'ja') {
                comment.style.display = 'none';
                btn.textContent = 'DRUCKFREIGABE ERTEILEN';
                btn.className   = 'df-btn';
            } else if (this.value === 'nein') {
                comment.style.display = 'block';
                btn.textContent = 'KEINE DRUCKFREIGABE ERTEILEN';
                btn.className   = 'df-btn btn-no';
            } else {
                comment.style.display = 'none';
                btn.textContent = 'KEINE AUSWAHL';
                btn.className   = 'df-btn';
            }
        });
    }


});
</script>

{% endif %}{# end showVerifyForm #}

{% endblock %}
