{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_main %}

<div class="container mt-5 mb-5">

    <h1 class="mb-4">Druckfreigabe {{ orderNumber }}</h1>

    {% if success %}
        <div class="alert alert-success">
            <strong>Vielen Dank!</strong> Ihre Druckfreigabe wurde erfolgreich übermittelt.
            {% if approvalValue == 'erteilt' %}
                Ihr Auftrag geht in die Produktion. Der Versand erfolgt in ca. 1 Woche.
            {% else %}
                Ihr Auftrag geht in die Grafikabteilung. Sie erhalten eine neue Druckvorschau per Mail.
            {% endif %}
        </div>
    {% endif %}

    {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    {# 1. Druckplatten Übersicht #}
    <h3>Druckplatten Übersicht</h3>

    <div class="row mt-3">
        {% for position in positions %}
            {% for plate in position.plates %}
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card p-3 h-100">
                        <h6 class="text-muted mb-2">
                            Position {{ position.number }} &mdash; Platte {{ plate.number }}
                        </h6>
                        <img
                            src="{{ plate.preview }}"
                            class="img-fluid mb-3"
                            style="height:280px; object-fit:contain;"
                            alt="Vorschau Pos. {{ position.number }} Platte {{ plate.number }}"
                        />
                        <a href="{{ plate.download }}" target="_blank" class="btn btn-outline-primary w-100">
                            Platte öffnen
                        </a>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# 2. Vorschau Zusammenfassung #}
    <div class="second-display-container mt-4">
        <div class="second-display-title">Vorschau Zusammenfassung</div>
        <div class="second-display">
            {% for position in positions %}
                {% for plate in position.plates %}
                    <div class="image-wrapper">
                        <div class="image">
                            <img src="{{ plate.preview }}" class="custom-image" />
                        </div>
                        <div class="text-center small mt-1">
                            Pos. {{ position.number }} / Pl. {{ plate.number }}
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </div>

    {# 3. Hinweistext & Formular #}
    {% if not success %}

    <div class="notice-text mt-5">
        Bitte die Originaldatei (Link „Platte öffnen") in 1:1 unbedingt prüfen!
        <br><br>
        <strong>WICHTIG:</strong> Bei Nachbestellungen / Ergänzungsbestellungen kann es zu Farbabweichungen kommen!
        Informieren Sie uns bitte <strong>vor</strong> der Druckfreigabe, falls es sich um eine Nach- bzw. Ergänzungsbestellung handelt.
        <br><br>
        <strong>Wie geht es weiter?</strong><br>
        Wählen Sie <strong>„Ja"</strong> → Auftrag geht in die Produktion (Versand in ca. 1 Woche).<br>
        Wählen Sie <strong>„Nein"</strong> → Notieren Sie Ihre Änderungswünsche → Auftrag geht in die Grafikabteilung.
    </div>

    <form method="post" action="{{ path('frontend.druckfreigabe.submit', { orderNumber: orderNumber }) }}" class="mt-4">

        {# 4. Druckfreigabe Auswahl #}
        <div class="mb-3">
            <label class="form-label fw-bold fs-5">Druckfreigabe erteilen?</label>
            <div class="d-flex gap-4 mt-2">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="approval" id="approvalJa" value="ja">
                    <label class="form-check-label fs-5" for="approvalJa">Ja</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="approval" id="approvalNein" value="nein">
                    <label class="form-check-label fs-5" for="approvalNein">Nein</label>
                </div>
            </div>
        </div>

        {# 5. Kommentarfeld (nur bei Nein) #}
        <div class="mb-3" id="commentField" style="display:none;">
            <label for="approvalComment" class="form-label fw-bold">Änderungswünsche:</label>
            <textarea
                id="approvalComment"
                name="comment"
                class="form-control"
                rows="4"
                placeholder="Bitte hier Änderungswünsche eintragen"
            ></textarea>
        </div>

        {# 6. Button #}
        <div class="mt-4">
            <button type="submit" id="approvalButton" class="btn btn-secondary btn-lg" disabled>
                Bitte wählen Sie Ja oder Nein
            </button>
        </div>

    </form>

    {% endif %}

</div>

<div class="footer-druckfreigabe mt-4 mb-4 text-center">
    <a href="/impressum">Impressum</a>
    &nbsp;&nbsp;|&nbsp;&nbsp;
    <a href="/kontaktformular">Kontakt</a>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    var radios      = document.querySelectorAll('input[name="approval"]');
    var commentField = document.getElementById('commentField');
    var button      = document.getElementById('approvalButton');

    if (!radios.length) return;

    radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
            button.disabled = false;
            if (this.value === 'ja') {
                commentField.style.display = 'none';
                button.textContent = 'Druckfreigabe erteilen';
                button.className   = 'btn btn-success btn-lg';
            } else {
                commentField.style.display = 'block';
                button.textContent = 'Keine Druckfreigabe erteilen';
                button.className   = 'btn btn-danger btn-lg';
            }
        });
    });
});
</script>

{% endblock %}
