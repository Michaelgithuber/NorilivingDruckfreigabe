{% sw_extends '@Storefront/storefront/page/account/order-history/order-item.html.twig' %}

{% block page_account_order_item_order_table_body_cell_toggle_order_details %}
    {{ parent() }}

    {% set druckfreigabe = page.extensions.druckfreigabe %}
    {% if druckfreigabe and druckfreigabe.hasOrder(order.orderNumber) %}
        <div class="mt-2">
            <a href="{{ path('frontend.druckfreigabe.page', { orderNumber: order.orderNumber }) }}"
               class="btn btn-primary btn-sm"
               target="_blank">
                Druckfreigabe
            </a>
        </div>
    {% endif %}
{% endblock %}
